# AWS Credentials
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_SESSION_TOKEN=your_session_token

# Discord Configuration
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_WEBHOOK=your_discord_webhook_url_here

# API Configuration
API_BASE_URL=https://lunaraxolotl.com

# Alert System Configuration
ALERTS_ENABLE=true
ALERTS_ENV=prod
ALERTS_DEDUPE_TTL_SEC=900
ALERTS_COOLDOWN_SEC=300
ALERTS_AGG_WINDOW_SEC=60
ALERTS_MAX_POSTS_PER_MIN=20
ALERTS_HEARTBEAT_INTERVAL_MIN=30
ALERTS_DIGEST_UTC_HOUR=9

# Alert Channel Routing
ALERTS_CHANNEL_INFO=#alerts
ALERTS_CHANNEL_WARN=#alerts
ALERTS_CHANNEL_CRIT=#pages

# Optional: Escalation Configuration
ALERTS_ESCALATE_AFTER=600
ALERTS_PAGERDUTY_WEBHOOK=
